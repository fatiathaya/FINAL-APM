    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Gauge animation
            const gaugeFill = document.getElementById('gaugeFillCircle');
            if (gaugeFill) {
                const circumference = parseFloat("<%= circumference %>");
                const offset = parseFloat("<%= dashoffset %>");
                setTimeout(() => {
                    gaugeFill.style.strokeDashoffset = offset;
                }, 200);
            }
            // Risk meter pointer animation
            const pointer = document.getElementById('riskMeterPointer');
            if (pointer) {
                const pct = parseFloat("<%= probability_percentage %>");
                setTimeout(() => {
                    pointer.style.left = Math.min(Math.max(pct, 2), 97) + '%';
                }, 300);
            }
        });
    </script>
    <script src="/js/main.js"></script>
